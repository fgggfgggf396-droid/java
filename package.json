{
  "name": "sovereign-master-brain",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build": "npx esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "node dist/index.js",
    "pm2:start": "npm run build && mkdir -p logs && pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop sovereign-x",
    "pm2:restart": "npm run build && pm2 restart sovereign-x",
    "pm2:logs": "pm2 logs sovereign-x",
    "pm2:status": "pm2 status"
  },
  "dependencies": {
    "axios": "^1.12.0",
    "express": "^4.21.2",
    "pako": "^2.1.0",
    "qs": "^6.15.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/node": "^24.7.0",
    "@types/pako": "^2.0.4",
    "@types/qs": "^6.14.0",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.25.0",
    "typescript": "5.6.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
